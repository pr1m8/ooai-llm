# Application-scoped credentials
OOAI_OPENAI_API_KEY=
OOAI_ANTHROPIC_API_KEY=
OOAI_GOOGLE_API_KEY=
OOAI_XAI_API_KEY=
OOAI_DEEPSEEK_API_KEY=
OOAI_MISTRAL_API_KEY=

# Optional native provider variables
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Google / Gemini Vertex AI settings
OOAI_GOOGLE_USE_VERTEXAI=
OOAI_GOOGLE_CLOUD_PROJECT=
OOAI_GOOGLE_CLOUD_LOCATION=

# LLM defaults and cache settings
OOAI_LLM__DEFAULT_MODEL=openai:gpt-5.4-mini
OOAI_LLM__CACHE__ENABLED=true
OOAI_LLM__CACHE__BACKEND=sqlite
OOAI_LLM__CACHE__PATH=
OOAI_LLM__CACHE__FILENAME=langchain_llm_cache.sqlite3

# Optional live-test provider filter, comma-separated.
# Example for running without Gemini and xAI:
# OOAI_LIVE_PROVIDERS=openai,anthropic,deepseek,mistral
OOAI_LIVE_PROVIDERS=

# Set to true when live e2e tests should fail instead of skip if a selected
# provider is missing credentials or optional SDK packages.
OOAI_REQUIRE_LIVE=false
