# Optional native provider variables
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Google / Gemini Vertex AI settings
OOAI_GOOGLE_USE_VERTEXAI=
